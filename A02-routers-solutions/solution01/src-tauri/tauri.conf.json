{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tool Router Evidence Console",
  "version": "0.1.0",
  "identifier": "tools.accio.router",
  "build": {
    "beforeDevCommand": "npm --prefix ui run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm --prefix ui run build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tool Router Evidence Console",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src https://api.openai.com"
    }
  }
}
